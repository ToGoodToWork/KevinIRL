# KevinStream - Shared Configuration
# Copy this to .env and fill in your values

# SRT stream passphrase (must match on Pi and OBS)
SRT_PASSPHRASE=changeme-use-a-strong-passphrase

# Home PC Tailscale IP (run `tailscale ip` on your PC)
HOME_PC_TAILSCALE_IP=100.x.y.z

# OBS WebSocket password (set in OBS > Tools > WebSocket Server Settings)
OBS_WS_PASSWORD=your-obs-websocket-password

# OBS WebSocket port (default 4455)
OBS_WS_PORT=4455

# SRT port (default 9000)
SRT_PORT=9000

# Dashboard port (default 8080)
DASHBOARD_PORT=8080
